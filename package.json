{
  "name": "bible-mcp",
  "version": "2.1.0",
  "description": "A Bible MCP server with search capabilities, powered by a custom Bible API on Cloudflare Workers + D1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "inspect": "npx @modelcontextprotocol/inspector@latest",
    "test": "node --experimental-strip-types --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "agents": "^0.5.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@cloudflare/workers-types": "^4.20250124.2",
    "typescript": "^5.7.3",
    "wrangler": "^4.2.0"
  }
}
